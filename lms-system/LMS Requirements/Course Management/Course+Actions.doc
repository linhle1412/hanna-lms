<ul local-id=3D"d5ed11aa-df9e-4f86-8361-868968a2b193">
<li local-id=3D"0f7d39f7-6664-4fb0-9409-2c0b8149eb47">
<p local-id=3D"5f9040e6-b0bf-49c0-ad9b-d2292b7b3275">7 days before start da=
te</p></li>
<li local-id=3D"66d0571b-7197-49c7-97f2-ff2c6c179be8">
<p local-id=3D"05d3ab8b-1360-4145-8031-fb7f03bf270f">3 days before start da=
te</p></li>
<li local-id=3D"ec4e078a-6b78-47e8-bb45-e92286ce2b8c">
<p local-id=3D"a9a17453-da4c-4c09-9d2c-d25560124624">1 day before start dat=
e</p></li>
</ul></li>
<li local-id=3D"97dceecc-1e54-49e2-9b08-c79a24cddcca">
<p local-id=3D"fcdbe812-ab34-41ec-85eb-ca52f25cc01a">Reminder subject: "[LM=
