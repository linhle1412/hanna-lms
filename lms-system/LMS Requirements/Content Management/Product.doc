</tr>
<tr>
<td class=3D"confluenceTd">
<p>File Size</p></td>
<td class=3D"confluenceTd">
<p>Size in MB/KB</p></td>
<td class=3D"confluenceTd">
<p>Sortable</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p>File Type</p></td>
