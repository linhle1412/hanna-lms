</tr>
<tr>
<td class=3D"confluenceTd">
<p>License</p></td>
<td class=3D"confluenceTd">
<p>Text display</p></td>
<td class=3D"confluenceTd">
<p>Edit button</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p>Duration</p></td>
<td class=3D"confluenceTd">
<p>"X hours" (auto-calculated)</p></td>
<td class=3D"confluenceTd">
<p>Read-only</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p>Code</p></td>
<td class=3D"confluenceTd">
<p>Text display</p></td>
<td class=3D"confluenceTd">
<p>Edit button</p></td>
</tr>
<tr>
<td class=3D"confluenceTd">
<p>Certificate</p></td>
<td class=3D"confluenceTd">
<p>Text display</p></td>
